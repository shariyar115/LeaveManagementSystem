{
  "openapi": "3.0.1",
  "info": {
    "title": "HR Leaves Management API",
    "description": "Leave requests, balances, types, approvals and settlements for the HR Leaves Management module.",
    "version": "v1"
  },
  "paths": {
    "/api/Employees": {
      "get": {
        "tags": [
          "Employees"
        ],
        "summary": "Lists all employees.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmployeeDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveBalances": {
      "get": {
        "tags": [
          "LeaveBalances"
        ],
        "summary": "Returns the per-type balances and total balance for an employee,\r\nincluding days accrued to date for accruing leave types.",
        "parameters": [
          {
            "name": "employeeId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Balance summary for the employee.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveBalanceSummaryDto"
                }
              }
            }
          },
          "404": {
            "description": "Employee not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveRequests": {
      "get": {
        "tags": [
          "LeaveRequests"
        ],
        "summary": "Returns leave requests, optionally filtered by employee, status, type and date range.",
        "parameters": [
          {
            "name": "employeeId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/LeaveStatus"
            }
          },
          {
            "name": "leaveTypeId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "fromDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "toDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of matching leave requests.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LeaveRequestDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "LeaveRequests"
        ],
        "summary": "Submits a new leave request after validating dates, overlaps and balance.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeaveSubmissionDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LeaveSubmissionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LeaveSubmissionDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created leave request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveRequestDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed (e.g. \"Insufficient leave balance\").",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveRequests/pending": {
      "get": {
        "tags": [
          "LeaveRequests"
        ],
        "summary": "Returns all requests currently awaiting approval.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LeaveRequestDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveRequests/{id}/approval": {
      "post": {
        "tags": [
          "LeaveRequests"
        ],
        "summary": "Approves or rejects a single pending request. Deducts balance on approval.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeaveApprovalDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LeaveApprovalDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LeaveApprovalDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Decision applied."
          },
          "400": {
            "description": "Invalid status or insufficient balance.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Request not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveRequests/bulk-approval": {
      "post": {
        "tags": [
          "LeaveRequests"
        ],
        "summary": "Approves or rejects multiple pending requests in one call.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkApprovalDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkApprovalDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BulkApprovalDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveRequests/{id}/cancel": {
      "post": {
        "tags": [
          "LeaveRequests"
        ],
        "summary": "Cancels a request, restoring the balance if it had already been approved.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveTypes": {
      "get": {
        "tags": [
          "LeaveTypes"
        ],
        "summary": "Lists all leave types (used to populate dropdowns and the HR management grid).",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LeaveTypeDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "LeaveTypes"
        ],
        "summary": "Creates a new leave type.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertLeaveTypeDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertLeaveTypeDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertLeaveTypeDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveTypeDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/LeaveTypes/{id}": {
      "get": {
        "tags": [
          "LeaveTypes"
        ],
        "summary": "Gets a single leave type by id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveTypeDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "LeaveTypes"
        ],
        "summary": "Updates an existing leave type (including the IsAccrued toggle).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertLeaveTypeDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertLeaveTypeDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertLeaveTypeDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveTypeDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "LeaveTypes"
        ],
        "summary": "Deletes a leave type that is not referenced by any request or balance.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Settlements": {
      "post": {
        "tags": [
          "Settlements"
        ],
        "summary": "Applies a manual balance adjustment and records it in the settlement history.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SettlementDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SettlementDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SettlementDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated balance.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveBalanceDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Employee, leave type or balance not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Settlements"
        ],
        "summary": "Returns the (in-memory) settlement history, optionally filtered by employee.",
        "parameters": [
          {
            "name": "employeeId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SettlementHistoryDto"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkApprovalDto": {
        "type": "object",
        "properties": {
          "requestIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/LeaveStatus"
          },
          "rejectionComment": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EmployeeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "hireDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "LeaveApprovalDto": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/LeaveStatus"
          },
          "rejectionComment": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LeaveBalanceDto": {
        "type": "object",
        "properties": {
          "leaveTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "leaveTypeName": {
            "type": "string",
            "nullable": true
          },
          "balance": {
            "type": "number",
            "format": "double"
          },
          "defaultDays": {
            "type": "integer",
            "format": "int32"
          },
          "isAccrued": {
            "type": "boolean"
          },
          "accruedToDate": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LeaveBalanceSummaryDto": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "employeeName": {
            "type": "string",
            "nullable": true
          },
          "totalBalance": {
            "type": "number",
            "format": "double"
          },
          "balances": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LeaveBalanceDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LeaveRequestDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "employeeName": {
            "type": "string",
            "nullable": true
          },
          "leaveTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "leaveTypeName": {
            "type": "string",
            "nullable": true
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "daysRequested": {
            "type": "integer",
            "format": "int32"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "reason": {
            "type": "string",
            "nullable": true
          },
          "rejectionComment": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "LeaveStatus": {
        "enum": [
          "Pending",
          "Approved",
          "Rejected",
          "Cancelled"
        ],
        "type": "string"
      },
      "LeaveSubmissionDto": {
        "required": [
          "employeeId",
          "endDate",
          "leaveTypeId",
          "startDate"
        ],
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "leaveTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LeaveTypeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "defaultDays": {
            "type": "integer",
            "format": "int32"
          },
          "isAccrued": {
            "type": "boolean"
          },
          "accrualRatePerMonth": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "SettlementDto": {
        "required": [
          "employeeId",
          "leaveTypeId"
        ],
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "leaveTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "newBalance": {
            "maximum": 1000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "reason": {
            "maxLength": 250,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SettlementHistoryDto": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "employeeName": {
            "type": "string",
            "nullable": true
          },
          "leaveTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "leaveTypeName": {
            "type": "string",
            "nullable": true
          },
          "previousBalance": {
            "type": "number",
            "format": "double"
          },
          "newBalance": {
            "type": "number",
            "format": "double"
          },
          "reason": {
            "type": "string",
            "nullable": true
          },
          "adjustedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "UpsertLeaveTypeDto": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "defaultDays": {
            "maximum": 366,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "isAccrued": {
            "type": "boolean"
          },
          "accrualRatePerMonth": {
            "maximum": 31,
            "minimum": 0,
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Employees",
      "description": "Employee lookup (single-user demo, but exposed for the UI selector)."
    },
    {
      "name": "LeaveBalances",
      "description": "Leave balances and accrual information per employee."
    },
    {
      "name": "LeaveRequests",
      "description": "Create, query and action employee leave requests."
    },
    {
      "name": "LeaveTypes",
      "description": "HR management of leave types (custom types with configurable defaults and accrual)."
    },
    {
      "name": "Settlements",
      "description": "Manual balance settlements (e.g. annual reset of unused vacation days) and their audit log."
    }
  ]
}